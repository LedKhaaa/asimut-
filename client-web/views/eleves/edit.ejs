<% title='Modifier ' + eleve.prenom + ' ' + eleve.nom %>

    <div style="margin-bottom:1rem;">
        <a href="/eleves/<%= eleve.id_eleve %>" class="btn btn-secondary">← Retour</a>
    </div>

    <div class="card">
        <h2 style="margin-bottom:1.2rem;">Modifier l'élève</h2>

        <% if (erreur) { %>
            <div class="erreur">
                <%= erreur %>
            </div>
            <% } %>

                <form action="/eleves/<%= eleve.id_eleve %>/edit" method="POST">
                    <div class="form-group">
                        <label for="nom">Nom</label>
                        <input type="text" id="nom" name="nom" value="<%= eleve.nom %>" required>
                    </div>
                    <div class="form-group">
                        <label for="prenom">Prénom</label>
                        <input type="text" id="prenom" name="prenom" value="<%= eleve.prenom %>" required>
                    </div>
                    <div class="form-group">
                        <label for="date_naissance">Date de naissance</label>
                        <input type="date" id="date_naissance" name="date_naissance"
                            value="<%= eleve.date_naissance ?? '' %>">
                    </div>
                    <div class="form-group">
                        <label for="id_classe">ID Classe</label>
                        <input type="number" id="id_classe" name="id_classe" value="<%= eleve.id_classe ?? '' %>">
                    </div>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </form>
    </div>